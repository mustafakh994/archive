# Copy to .env.testing and adjust. Use a different POSTGRES_DB name than production.
POSTGRES_DB=fromstoarchive_testing
POSTGRES_USER=testing_archive_user
POSTGRES_PASSWORD=change_me_strong_password

JWT_SECRET=change_me_at_least_32_characters_long_secret
JWT_ISSUER=FormsManagementAPI
JWT_AUDIENCE=FormsManagementClients
JWT_EXP_MIN=60
JWT_REFRESH_DAYS=7

# If you copy DB rows that include encrypted attachments, this must match production.
ATTACHMENT_ENCRYPTION_KEY_BASE64=paste_from_production_if_needed

ATTACHMENT_PDF_JOBS_INTERNAL_API_KEY=generate_a_new_random_key_for_testing
